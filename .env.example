# Chat with May — Environment Variables
PORT=3000

# Groq API Key (for fast & free-tier Whisper speech recognition) [required]
GROQ_API_KEY=

# LLM Gateway (OpenClaw API endpoint)
# GATEWAY_URL: The base URL of the LLM gateway server [required]
# GATEWAY_TOKEN: Bearer token for authenticating with the gateway [required]
GATEWAY_URL=http://127.0.0.1:6100
GATEWAY_TOKEN=

# Auth
# AUTH_TOKEN: The master passphrase users enter to access the chat [required]
# ADMIN_SECRET: Secret key for admin API routes (user list) [optional]
# ADMIN_EMAIL: Email address that receives new user registration notifications [optional, default: df41022@gmail.com]
AUTH_TOKEN=
ADMIN_SECRET=
ADMIN_EMAIL=

# Public URL (used to generate approval links in admin notification emails)
# Set to your deployed domain [optional, default: https://chat-with-may.vercel.app]
PUBLIC_URL=

# SMTP (for sending registration/approval emails via Gmail)
# SMTP_USER: Gmail address used as the sender [optional, falls back to webhook notification]
# SMTP_PASS: Gmail app password (not your regular password) [optional, falls back to webhook notification]
SMTP_USER=df41022@gmail.com
SMTP_PASS=
